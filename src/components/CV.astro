---
import cvFileEn from '../assets/MARTI_VILAS_CV_2025_ENGLISH.pdf';
import cvFileEs from '../assets/MARTI_VILAS_CV_2025_CORREGIDO_WEB.pdf';
import { defaultLocale, t, type Locale } from '../i18n';

const { locale = defaultLocale } = Astro.props as { locale?: Locale };
const highlights = t('cv_highlights', locale);
const cvFile = locale === 'en' ? cvFileEn : cvFileEs;
const cvDownloadName = locale === 'en' ? 'Marti_Vilas_CV_EN.pdf' : 'Marti_Vilas_CV_ES.pdf';
---

<section class="cv" id="cv" aria-labelledby="cv-title">
	<div>
		<p class="eyebrow">{t('cv_label', locale)}</p>
		<h2 id="cv-title">{t('professional_profile_title', locale)}</h2>
		<p class="intro">{t('cv_summary', locale)}</p>
	</div>
	<ul>
		{highlights.map((item) => <li>{item}</li>)}
	</ul>
	<div class="actions">
		<a href={cvFile} class="button" download={cvDownloadName}>{t('download_cv_button', locale)}</a>
	</div>
</section>

<style>
	.cv {
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(0, 1fr) auto;
		gap: 2rem;
		align-items: center;
		padding: clamp(3rem, 6vw, 5rem) 0;
		border-bottom: 1px solid var(--color-border);
	}

	.eyebrow {
		margin: 0 0 0.6rem;
		color: var(--color-accent);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	h2 {
		margin: 0;
		color: var(--color-text);
		font-size: clamp(2rem, 3.5vw, 3.2rem);
		line-height: 1;
	}

	.intro {
		max-width: 34rem;
		margin: 1rem 0 0;
		color: var(--color-text-muted);
		line-height: 1.65;
	}

	ul {
		display: grid;
		gap: 0.8rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	li {
		position: relative;
		padding-left: 1.3rem;
		color: var(--color-text);
		line-height: 1.55;
	}

	li::before {
		position: absolute;
		top: 0.72em;
		left: 0;
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 50%;
		background: var(--color-success);
		content: "";
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		justify-content: end;
	}

	.button {
		display: inline-flex;
		min-width: 124px;
		justify-content: center;
		border-radius: 8px;
		background: var(--color-primary);
		padding: 0.9rem 1.2rem;
		color: var(--color-button-text);
		font-weight: 800;
		text-decoration: none;
	}

	.button:hover {
		background: var(--color-primary-hover);
	}

	.button.secondary {
		border: 1px solid var(--color-accent);
		background: transparent;
		color: var(--color-accent);
	}

	.button.secondary:hover {
		background: var(--color-accent-soft);
	}

	@media (max-width: 920px) {
		.cv {
			grid-template-columns: 1fr;
			align-items: start;
		}

		.actions {
			justify-content: start;
		}

		.button {
			width: fit-content;
		}
	}

	@media (max-width: 480px) {
		.actions {
			flex-direction: column;
			align-items: stretch;
		}

		.button {
			width: 100%;
			min-width: 0;
		}
	}
</style>
