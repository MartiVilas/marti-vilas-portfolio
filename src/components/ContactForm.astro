---
import { defaultLocale, t, type Locale } from '../i18n';

const { locale = defaultLocale } = Astro.props as { locale?: Locale };
---

<section class="contact" id="contacto" aria-labelledby="contact-title">
	<div>
		<p class="eyebrow">{t('contact_label', locale)}</p>
		<h2 id="contact-title">{t('contact_title', locale)}</h2>
		<p class="intro">{t('contact_summary', locale)}</p>
	</div>

	<form
		class="contact-form"
		method="post"
		action="/api/brevo-contact"
		data-contact-form
		data-sending-message={t('contact_sending_message', locale)}
		data-success-message={t('contact_success_message', locale)}
		data-error-message={t('contact_error_message', locale)}
	>
		<label>
			<span>{t('contact_name_label', locale)}</span>
			<input id="contact-name" name="name" type="text" placeholder={t('contact_name_placeholder', locale)} required />
		</label>
		<label>
			<span>{t('contact_email_label', locale)}</span>
			<input id="contact-email" name="email" type="email" placeholder={t('contact_email_placeholder', locale)} required />
		</label>
		<label class="full">
			<span>{t('contact_message_label', locale)}</span>
			<textarea id="contact-message" name="message" rows="5" placeholder={t('contact_message_placeholder', locale)}></textarea>
		</label>
		<label class="consent full">
			<input name="consent" type="checkbox" required />
			<span>{t('contact_consent_label', locale)}</span>
		</label>
		<input class="honeypot" name="website" type="text" tabindex="-1" autocomplete="off" />
		<div class="form-footer full">
			<p class="status" data-contact-status aria-live="polite"></p>
			<button type="submit">{t('contact_submit_button', locale)}</button>
		</div>
	</form>
</section>

<script>
	const forms = document.querySelectorAll("[data-contact-form]");

	forms.forEach((form) => {
		form.addEventListener("submit", async (event) => {
			event.preventDefault();

			if (!(form instanceof HTMLFormElement)) return;

			const status = form.querySelector("[data-contact-status]");
			const button = form.querySelector("button[type='submit']");
			const sendingMessage = form.dataset.sendingMessage ?? "Sending...";
			const successMessage = form.dataset.successMessage ?? "Message sent.";
			const errorMessage = form.dataset.errorMessage ?? "Something went wrong.";

			if (status) status.textContent = sendingMessage;
			if (button instanceof HTMLButtonElement) button.disabled = true;

			try {
				const formData = new FormData(form);
				const response = await fetch(form.action, {
					method: "POST",
					headers: {
						"Content-Type": "application/json",
					},
					body: JSON.stringify({
						name: formData.get("name"),
						email: formData.get("email"),
						message: formData.get("message"),
						consent: formData.get("consent") === "on",
						website: formData.get("website"),
					}),
				});

				if (!response.ok) throw new Error("Request failed");

				form.reset();
				if (status) status.textContent = successMessage;
			} catch {
				if (status) status.textContent = errorMessage;
			} finally {
				if (button instanceof HTMLButtonElement) button.disabled = false;
			}
		});
	});
</script>

<style>
	.contact {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
		gap: clamp(2rem, 5vw, 4rem);
		align-items: center;
		width: min(1080px, 100%);
		margin-inline: auto;
		padding: clamp(4rem, 8vw, 6rem) 0;
		border-bottom: 1px solid var(--color-border);
	}

	.eyebrow {
		margin: 0 0 0.6rem;
		color: var(--color-accent);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	h2 {
		margin: 0;
		color: var(--color-text);
		font-size: clamp(2rem, 4vw, 3.6rem);
		line-height: 1;
	}

	.intro {
		max-width: 30rem;
		margin: 1rem 0 0;
		color: var(--color-text-muted);
		line-height: 1.65;
	}

	.contact-form {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
		width: min(100%, 390px);
		justify-self: center;
		border: 1px solid var(--color-border);
		border-radius: 8px;
		background: var(--color-bg-secondary);
		padding: clamp(1rem, 2vw, 1.35rem);
		box-shadow: 0 18px 45px rgba(var(--color-accent-rgb), 0.08);
	}

	label {
		display: grid;
		gap: 0.45rem;
		color: var(--color-text);
		font-size: 0.92rem;
		font-weight: 800;
	}

	.full {
		grid-column: auto;
	}

	input,
	textarea {
		width: 95%;
		border: 1px solid var(--color-border);
		border-radius: 8px;
		background: var(--color-bg-tertiary);
		padding: 0.65rem 0.75rem;
		color: var(--color-text);
		font: inherit;
		outline: none;
	}

	input:not([type="checkbox"]) {
		height: 2.65rem;
	}

	input:focus,
	textarea:focus {
		border-color: var(--color-accent);
		box-shadow: 0 0 0 3px rgba(var(--color-accent-rgb), 0.12);
	}

	textarea {
		min-height: 112px;
		resize: vertical;
	}

	.consent {
		display: flex;
		align-items: start;
		gap: 0.65rem;
		color: var(--color-text-muted);
		font-size: 0.88rem;
		font-weight: 650;
		line-height: 1.45;
	}

	.consent input {
		flex: 0 0 auto;
		width: 1rem;
		height: 1rem;
		margin-top: 0.15rem;
		padding: 0;
		accent-color: var(--color-primary);
	}

	.honeypot {
		position: absolute;
		left: -9999px;
	}

	.form-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.status {
		flex: 1;
		margin: 0;
		color: var(--color-text-muted);
		line-height: 1.4;
	}

	button {
		border: 0;
		border-radius: 8px;
		background: var(--color-primary);
		padding: 0.75rem 1.05rem;
		color: var(--color-text);
		font: inherit;
		font-weight: 850;
		cursor: pointer;
	}

	button:hover {
		background: var(--color-primary-hover);
	}

	button:disabled {
		cursor: wait;
		opacity: 0.7;
	}

	@media (max-width: 860px) {
		.contact {
			grid-template-columns: 1fr;
			align-items: start;
		}

		.contact-form {
			justify-self: stretch;
			width: 100%;
			grid-template-columns: 1fr;
		}

		.form-footer {
			align-items: stretch;
			flex-direction: column;
		}

		.form-footer button {
			width: 100%;
		}
	}
</style>
