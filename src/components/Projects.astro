---
import { defaultLocale, t, type Locale } from '../i18n';

const { locale = defaultLocale } = Astro.props as { locale?: Locale };
const projects = t('projects', locale);

const toolIcons: Record<string, string> = {
	API: "https://cdn.simpleicons.org/openapiinitiative/6BA539",
	Astro: "https://cdn.simpleicons.org/astro/FF5A03",
	CSS: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/css3/css3-original.svg",
	HTML: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/html5/html5-original.svg",
	JavaScript: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-original.svg",
	LocalStorage: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/chrome/chrome-original.svg",
	SEO: "https://cdn.simpleicons.org/google/4285F4",
	UI: "https://cdn.simpleicons.org/figma/F24E1E",
	UX: "https://cdn.simpleicons.org/figma/F24E1E",
};
---

<section class="projects" id="proyectos" aria-labelledby="projects-title">
	<div class="section-heading">
		<p class="eyebrow">{t('projects_label', locale)}</p>
		<h2 id="projects-title">{t('recent_work_title', locale)}</h2>
	</div>
	<div class="project-grid">
		{
			projects.map((project) => (
				<article class:list={['project-card', 'image' in project && project.image && 'project-card-with-image']}>
					<div class="project-copy">
						<span>{project.type}</span>
						<h3>{project.title}</h3>
						<p>{project.description}</p>
					</div>
					{
						'url' in project && 'image' in project && project.url && project.image && (
							<a
								class="project-media"
								href={project.url}
								target="_blank"
								rel="noreferrer"
								aria-label={project.title}
							>
								<img src={project.image} alt={project.title} loading="lazy" />
							</a>
						)
					}

					<ul aria-label={`${t('technologies_label', locale)} ${project.title}`}>
						{project.tools.map((tool) => (
							<li>
								{toolIcons[tool] && <img src={toolIcons[tool]} alt="" aria-hidden="true" loading="lazy" />}
								{tool}
							</li>
						))}
					</ul>
				</article>
			))
		}
	</div>
</section>

<style>
	.projects {
		padding: clamp(4rem, 8vw, 7rem) 0;
		border-bottom: 1px solid var(--color-border);
	}

	.section-heading {
		display: flex;
		flex-wrap: wrap;
		align-items: end;
		justify-content: space-between;
		gap: 1rem 2rem;
		margin-bottom: 2rem;
	}

	.eyebrow {
		margin: 0 0 0.6rem;
		color: var(--color-accent);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	h2 {
		margin: 0;
		color: var(--color-text);
		font-size: clamp(2rem, 4vw, 3.6rem);
		line-height: 1;
	}

	.project-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.project-card {
		display: flex;
		min-height: 320px;
		flex-direction: column;
		justify-content: space-between;
		border: 1px solid var(--color-border);
		border-radius: 8px;
		background: var(--color-bg-secondary);
		padding: clamp(1.1rem, 2vw, 1.5rem);
		box-shadow: 0 18px 45px rgba(var(--color-accent-rgb), 0.08);
	}

	.project-card-with-image {
		justify-content: start;
		min-height: 0;
		padding: 1rem;
	}

	.project-card-with-image .project-copy {
		min-height: 205px;
	}

	.project-card:hover {
		box-shadow: 0 18px 45px rgba(var(--color-accent-rgb), 0.16);
	}

	.project-media {
		display: block;
		overflow: hidden;
		margin: 1.35rem 0 0;
		aspect-ratio: 16 / 9;
		border: 0;
		border-radius: 5px;
		background:
			radial-gradient(circle at 18% 18%, rgba(var(--color-accent-rgb), 0.3), transparent 34%),
			linear-gradient(135deg, var(--color-bg-tertiary), var(--color-bg-secondary));
	}

	.project-media img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center center;
		transition: transform 0.35s ease;
	}

	.project-media:hover img,
	.project-media:focus-visible img {
		transform: scale(1.2);
	}

	span {
		color: var(--color-accent);
		font-size: 0.82rem;
		font-weight: 800;
		text-transform: uppercase;
	}

	h3 {
		margin: 0.85rem 0 1rem;
		color: var(--color-text);
		font-size: clamp(1.35rem, 2vw, 1.75rem);
	}

	p {
		margin: 0;
		color: var(--color-text-muted);
		line-height: 1.65;
	}

	ul {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin: 2rem 0 0;
		padding: 0;
		list-style: none;
	}

	li {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.4rem;
		min-height: 2.35rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		padding: 0.42rem 0.72rem;
		background: var(--color-bg-tertiary);
		color: var(--color-text);
		font-size: 0.85rem;
		font-weight: 700;
	}

	li img {
		display: block;
		width: 1.05rem !important;
		height: 1.05rem !important;
		max-width: 1.05rem !important;
		max-height: 1.05rem !important;
		flex: 0 0 auto;
		object-fit: contain;
	}

	.project-card-with-image li {
		gap: 0.32rem;
		min-height: 2rem;
		padding: 0.34rem 0.54rem;
		font-size: 0.78rem;
	}

	.project-card-with-image li img {
		width: 0.9rem !important;
		height: 0.9rem !important;
		max-width: 0.9rem !important;
		max-height: 0.9rem !important;
	}

	@media (max-width: 920px) {
		.project-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.project-card {
			min-height: 280px;
		}

		.project-card-with-image .project-copy {
			min-height: 180px;
		}
	}

	@media (max-width: 600px) {
		.project-grid {
			grid-template-columns: 1fr;
		}

		.project-card {
			min-height: 240px;
		}

		.project-card-with-image .project-copy {
			min-height: 0;
		}
	}
</style>
