---
import { defaultLocale, t, type Locale } from '../i18n';

const { locale = defaultLocale } = Astro.props as { locale?: Locale };
const studies = t('studies', locale);
---

<section class="education" id="estudios" aria-labelledby="education-title">
	<div class="section-heading">
		<p class="eyebrow">{t('education_label', locale)}</p>
		<h2 id="education-title">{t('education_title', locale)}</h2>
	</div>
	<div class="study-list">
		{
			studies.map((study) => (
				<article>
					<p class="period">{study.period}</p>
					<h3>{study.title}</h3>
					<p>{study.center}</p>
				</article>
			))
		}
	</div>
</section>

<style>
	.education {
		padding: clamp(4rem, 8vw, 7rem) 0;
	}

	.section-heading {
		margin-bottom: 2rem;
	}

	.eyebrow {
		margin: 0 0 0.6rem;
		color: var(--color-accent);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	h2 {
		margin: 0;
		color: var(--color-text);
		font-size: clamp(2rem, 4vw, 3.6rem);
		line-height: 1;
	}

	.study-list {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	article {
		border: 1px solid var(--color-border);
		border-left: 4px solid var(--color-accent);
		border-radius: 8px;
		background: var(--color-bg-secondary);
		padding: 1.25rem;
	}

	.period {
		margin: 0 0 1rem;
		color: var(--color-accent);
		font-size: 0.85rem;
		font-weight: 800;
	}

	h3 {
		margin: 0 0 0.7rem;
		color: var(--color-text);
		font-size: 1.25rem;
		line-height: 1.2;
	}

	p {
		margin: 0;
		color: var(--color-text-muted);
		line-height: 1.55;
	}

	@media (max-width: 860px) {
		.study-list {
			grid-template-columns: 1fr;
		}
	}
</style>
