---
import { defaultLocale, t, type Locale } from '../i18n';

const { locale = defaultLocale } = Astro.props as { locale?: Locale };
const studies = t('studies', locale);
---

<section class="education" id="estudios" aria-labelledby="education-title">
	<div class="section-heading">
		<p class="eyebrow">{t('education_label', locale)}</p>
		<h2 id="education-title">{t('education_title', locale)}</h2>
	</div>
	<div class="study-list">
		{
			studies.map((study) => (
				<article class:list={["study-card", { featured: study.featured }]}>
					<div class="study-meta">
						<p class="period">{study.period}</p>
						{study.badge && <span class="badge">{study.badge}</span>}
					</div>
					<h3>{study.title}</h3>
					<p class="center">{study.center}</p>
					{study.description && <p class="description">{study.description}</p>}
				</article>
			))
		}
	</div>
</section>

<style>
	.education {
		padding: clamp(4rem, 8vw, 7rem) 0;
	}

	.section-heading {
		margin-bottom: 2rem;
	}

	.eyebrow {
		margin: 0 0 0.6rem;
		color: var(--color-accent);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	h2 {
		margin: 0;
		color: var(--color-text);
		font-size: clamp(2rem, 4vw, 3.6rem);
		line-height: 1;
	}

	.study-list {
		display: grid;
		grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
		gap: 1.25rem;
	}

	.study-card {
		display: flex;
		flex-direction: column;
		border: 1px solid var(--color-border);
		border-left: 4px solid var(--color-accent);
		border-radius: 8px;
		background: var(--color-bg-secondary);
		padding: 1.5rem;
	}

	.study-card.featured {
		border-left-width: 6px;
		background: linear-gradient(
			135deg,
			rgba(var(--color-accent-rgb), 0.12),
			var(--color-bg-secondary) 60%
		);
		box-shadow: 0 18px 45px rgba(var(--color-accent-rgb), 0.12);
	}

	.study-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.6rem;
		margin-bottom: 0.9rem;
	}

	.period {
		margin: 0;
		color: var(--color-accent);
		font-size: 0.85rem;
		font-weight: 800;
	}

	.badge {
		display: inline-flex;
		align-items: center;
		border-radius: 999px;
		background: rgba(34, 197, 94, 0.15);
		padding: 0.2rem 0.65rem;
		color: var(--color-success);
		font-size: 0.72rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	h3 {
		margin: 0 0 0.6rem;
		color: var(--color-text);
		font-size: 1.25rem;
		line-height: 1.25;
	}

	.study-card.featured h3 {
		font-size: clamp(1.4rem, 1.8vw, 1.7rem);
	}

	.center {
		margin: 0;
		color: var(--color-text-muted);
		line-height: 1.55;
		font-weight: 700;
	}

	.description {
		margin: 0.9rem 0 0;
		color: var(--color-text-muted);
		line-height: 1.6;
	}

	@media (max-width: 860px) {
		.study-list {
			grid-template-columns: 1fr;
		}
	}
</style>
