---
const studies = [
	{
		title: "Desarrollo de Aplicaciones Web",
		center: "Formación profesional",
		period: "En curso",
	},
	{
		title: "Fundamentos de UX/UI y accesibilidad",
		center: "Autoformación y práctica",
		period: "2024 - Actualidad",
	},
	{
		title: "Inglés técnico aplicado a desarrollo",
		center: "Recursos y documentación",
		period: "Continuo",
	},
];
---

<section class="education" id="estudios" aria-labelledby="education-title">
	<div class="section-heading">
		<p class="eyebrow">Estudios</p>
		<h2 id="education-title">Formación</h2>
	</div>
	<div class="study-list">
		{
			studies.map((study) => (
				<article>
					<p class="period">{study.period}</p>
					<h3>{study.title}</h3>
					<p>{study.center}</p>
				</article>
			))
		}
	</div>
</section>

<style>
	.education {
		padding: clamp(4rem, 8vw, 7rem) 0;
	}

	.section-heading {
		margin-bottom: 2rem;
	}

	.eyebrow {
		margin: 0 0 0.6rem;
		color: #8b3f2f;
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	h2 {
		margin: 0;
		font-size: clamp(2rem, 4vw, 3.6rem);
		line-height: 1;
	}

	.study-list {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	article {
		border-left: 4px solid #2f6f73;
		background: rgba(255, 250, 242, 0.72);
		padding: 1.25rem;
	}

	.period {
		margin: 0 0 1rem;
		color: #8b3f2f;
		font-size: 0.85rem;
		font-weight: 800;
	}

	h3 {
		margin: 0 0 0.7rem;
		font-size: 1.25rem;
		line-height: 1.2;
	}

	p {
		margin: 0;
		color: #565149;
		line-height: 1.55;
	}

	@media (max-width: 860px) {
		.study-list {
			grid-template-columns: 1fr;
		}
	}
</style>
