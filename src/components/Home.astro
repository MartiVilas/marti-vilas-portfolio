---
import CV from './CV.astro';
import ContactForm from './ContactForm.astro';
import Education from './Education.astro';
import Experience from './Experience.astro';
import Layout from '../layouts/Layout.astro';
import Projects from './Projects.astro';
import SkillsLanguages from './SkillsLanguages.astro';
import Synopsis from './Synopsis.astro';
import { defaultLocale, t, type Locale } from '../i18n';

const { locale = defaultLocale } = Astro.props as { locale?: Locale };

const languageLinks = [
	{
		locale: "es",
		href: "/",
		flag: "fi-es",
		label: t('spanish_language', locale),
	},
	{
		locale: "en",
		href: "/en/",
		flag: "fi-gb",
		label: t('english_language', locale),
	},
] as const;

const currentLanguage = languageLinks.find((language) => language.locale === locale) ?? languageLinks[0];
const nextLanguage = languageLinks.find((language) => language.locale !== locale) ?? languageLinks[0];
---

<Layout locale={locale}>
	<header class="site-header">
		<a href="#inicio" class="brand">{t('personal_name', locale)}</a>
		<div class="header-actions">
			<nav aria-label={t('main_navigation', locale)}>
				<a href="#skills">{t('skills_link', locale)}</a>
				<a href="#proyectos">{t('projects_link', locale)}</a>
				<a href="#cv">{t('cv_link', locale)}</a>
				<a href="#contacto">{t('contact_link', locale)}</a>
				<a href="#experiencia">{t('experience_link', locale)}</a>
				<a href="#estudios">{t('education_link', locale)}</a>
			</nav>
			<a class="language-switcher" href={nextLanguage.href} aria-label={nextLanguage.label} title={nextLanguage.label}>
					<span class={`fi ${currentLanguage.flag}`} aria-hidden="true"></span>
			</a>
		</div>
	</header>

	<main id="inicio">
		<section class="hero" aria-labelledby="hero-title">
			<div class="hero-copy">
				<p class="eyebrow">{t('personal_portfolio', locale)}</p>
				<h1 id="hero-title">{t('personal_name', locale)}</h1>
				<p>{t('introduction_text', locale)}</p>
				<div class="hero-actions">
					<a href="#proyectos" class="primary">{t('projects_button', locale)}</a>
					<a href="#cv">{t('cv_button', locale)}</a>
				</div>
			</div>
			<div class="hero-panel" aria-label={t('quick_summary', locale)}>
				<p>{t('availability_text', locale)}</p>
				<span>{t('technology_stack', locale)}</span>
			</div>
		</section>

		<div class="content">
			<Synopsis locale={locale} />
			<SkillsLanguages locale={locale} />
			<Projects locale={locale} />
			<CV locale={locale} />
			<Experience locale={locale} />
			<Education locale={locale} />
			<ContactForm locale={locale} />
		</div>
	</main>
</Layout>

<style>
	.site-header {
		position: sticky;
		top: 5px;
		z-index: 10;
		display: flex;
		align-items: center;
		justify-content: center;
		width: fit-content;
		max-width: calc(100% - 2rem);
		margin: 13px auto 0;
		gap: 1.2rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: rgba(11, 18, 32, 0.88);
		padding: 0.65rem 0.75rem 0.65rem 1rem;
		backdrop-filter: blur(18px);
		box-shadow: 0 18px 45px rgba(0, 0, 0, 0.26);
	}

	.brand {
		font-weight: 900;
		text-decoration: none;
	}

	.header-actions {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1rem;
	}

	nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.45rem 1rem;
		color: var(--color-text-muted);
		font-size: 0.95rem;
		font-weight: 700;
	}

	nav a {
		text-decoration: none;
	}

	.language-switcher {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.8rem;
		height: 2.35rem;
		background: rgba(15, 23, 42, 0.8);
		cursor: pointer;
		text-decoration: none;
		transition:
			background 0.2s ease,
			border-color 0.2s ease,
			transform 0.2s ease;
	}

	.language-switcher:hover {
		border-color: var(--color-accent);
		background: rgba(var(--color-accent-rgb), 0.12);
		transform: translateY(-1px);
	}

	.fi {
		width: 1.55rem;
		border-radius: 2px;
		box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.12);
	}

	.hero {
		display: grid;
		min-height: calc(100svh - 66px);
		grid-template-columns: minmax(0, 1fr) minmax(280px, 0.36fr);
		gap: clamp(2rem, 5vw, 5rem);
		align-items: end;
		padding: clamp(3rem, 7vw, 6rem) clamp(1rem, 4vw, 3rem) clamp(2rem, 5vw, 4rem);
		background:
			linear-gradient(135deg, rgba(11, 18, 32, 0.96), rgba(17, 28, 46, 0.86)),
			url("https://images.unsplash.com/photo-1497366754035-f200968a6e72?auto=format&fit=crop&w=1800&q=80")
				center/cover;
	}

	.hero-copy {
		max-width: 950px;
	}

	.eyebrow {
		margin: 0 0 0.8rem;
		color: var(--color-accent);
		font-size: 0.8rem;
		font-weight: 900;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	h1 {
		margin: 0;
		color: var(--color-text);
		font-size: clamp(4.2rem, 13vw, 11rem);
		line-height: 0.82;
		font-weight: 950;
	}

	.hero-copy > p:not(.eyebrow) {
		max-width: 690px;
		margin: 1.4rem 0 0;
		color: var(--color-text-muted);
		font-size: clamp(1.15rem, 2vw, 1.55rem);
		line-height: 1.45;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 2rem;
	}

	.hero-actions a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--color-accent);
		border-radius: 8px;
		background: transparent;
		padding: 0.9rem 1.1rem;
		color: var(--color-accent);
		font-weight: 850;
		text-decoration: none;
	}

	.hero-actions .primary {
		border-color: var(--color-primary);
		background: var(--color-primary);
		color: var(--color-text);
	}

	.hero-actions .primary:hover {
		background: var(--color-primary-hover);
	}

	.hero-actions a:not(.primary):hover {
		background: rgba(var(--color-accent-rgb), 0.12);
	}

	.hero-panel {
		border: 1px solid var(--color-border);
		border-radius: 8px;
		background: rgba(17, 28, 46, 0.88);
		padding: 1.2rem;
		box-shadow: 0 22px 55px rgba(var(--color-accent-rgb), 0.12);
	}

	.hero-panel p {
		margin: 0 0 1rem;
		font-size: 1.2rem;
		font-weight: 850;
		line-height: 1.25;
	}

	.hero-panel span {
		color: var(--color-success);
		font-size: 0.95rem;
		font-weight: 750;
	}

	.content {
		width: min(1180px, calc(100% - 2rem));
		margin: 0 auto;
	}

	@media (max-width: 850px) {
		.site-header {
			position: sticky;
			align-items: center;
			flex-direction: column;
			border-radius: 22px;
			padding: 0.9rem;
		}

		.header-actions {
			align-items: center;
			flex-direction: column;
		}

		nav {
			justify-content: center;
		}

		.hero {
			min-height: auto;
			grid-template-columns: 1fr;
			align-items: start;
			padding-top: 5rem;
		}
	}
</style>
