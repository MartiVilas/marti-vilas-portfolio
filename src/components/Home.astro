---
import CV from './CV.astro';
import ContactForm from './ContactForm.astro';
import Education from './Education.astro';
import Experience from './Experience.astro';
import Header from './Header.astro';
import Layout from '../layouts/Layout.astro';
import PortfolioChat from './PortfolioChat.astro';
import Projects from './Projects.astro';
import SkillsLanguages from './SkillsLanguages.astro';
import Synopsis from './Synopsis.astro';
import { defaultLocale, t, type Locale } from '../i18n';

const { locale = defaultLocale } = Astro.props as { locale?: Locale };
const socialLinks = t('social_links', locale);
---

<Layout locale={locale}>
	<Header locale={locale} />

	<main id="inicio">
		<section class="hero" aria-labelledby="hero-title">
			<div class="hero-copy">
				<p class="eyebrow">{t('personal_portfolio', locale)}</p>
				<h1 id="hero-title">{t('personal_name', locale)}</h1>
				<p>{t('introduction_text', locale)}</p>
				<div class="hero-actions">
					<a href="#proyectos" class="primary">{t('projects_button', locale)}</a>
					<a href="#cv">{t('cv_button', locale)}</a>
					<nav class="social-links" aria-label={t('social_links_label', locale)}>
						{socialLinks.map((link) => (
							<a href={link.url} target="_blank" rel="noreferrer">
								<img class="social-icon" src={link.icon} alt="" aria-hidden="true" loading="lazy" />
								{link.label}
							</a>
						))}
					</nav>
				</div>
			</div>
			<div class="hero-panel" aria-label={t('quick_summary', locale)}>
				<p>{t('availability_text', locale)}</p>
				<span>{t('technology_stack', locale)}</span>
			</div>
		</section>

		<div class="content">
			<Synopsis locale={locale} />
			<SkillsLanguages locale={locale} />
			<Projects locale={locale} />
			<CV locale={locale} />
			<Experience locale={locale} />
			<Education locale={locale} />
			<ContactForm locale={locale} />
		</div>
	</main>

	<PortfolioChat locale={locale} />
</Layout>

<style>
	.hero {
		display: grid;
		min-height: clamp(520px, 72svh, 680px);
		grid-template-columns: minmax(0, 1fr) minmax(280px, 0.36fr);
		gap: clamp(2rem, 5vw, 5rem);
		align-items: center;
		padding: clamp(2.5rem, 5vw, 4.5rem) clamp(1rem, 4vw, 3rem) clamp(2rem, 4vw, 3rem);
		background: linear-gradient(135deg, var(--color-hero-overlay-start), var(--color-hero-overlay-end));
	}

	.hero-copy {
		max-width: 950px;
	}

	.eyebrow {
		margin: 0 0 0.8rem;
		color: var(--color-accent);
		font-size: 0.8rem;
		font-weight: 900;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	h1 {
		margin: 0;
		color: var(--color-text);
		font-size: clamp(2.6rem, 11vw, 11rem);
		line-height: 0.86;
		font-weight: 950;
		word-break: break-word;
	}

	.hero-copy > p:not(.eyebrow) {
		max-width: 690px;
		margin: 1.4rem 0 0;
		color: var(--color-text-muted);
		font-size: clamp(1.15rem, 2vw, 1.55rem);
		line-height: 1.45;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 2rem;
	}

	.hero-actions a,
	.social-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--color-accent);
		border-radius: 8px;
		background: transparent;
		padding: 0.9rem 1.1rem;
		color: var(--color-accent);
		font-weight: 850;
		text-decoration: none;
	}

	.hero-actions .primary {
		border-color: var(--color-primary);
		background: var(--color-primary);
		color: var(--color-button-text);
	}

	.hero-actions .primary:hover {
		background: var(--color-primary-hover);
	}

	.hero-actions a:not(.primary):hover {
		background: var(--color-accent-soft);
	}

	.social-links {
		display: contents;
	}

	.social-links a {
		gap: 0.45rem;
	}

	.social-icon {
		display: block;
		width: 1.1rem !important;
		height: 1.1rem !important;
		max-width: 1.1rem !important;
		max-height: 1.1rem !important;
		flex: 0 0 auto;
		object-fit: contain;
	}

	.social-links a:hover {
		background: var(--color-accent-soft);
	}

	.hero-panel {
		border: 1px solid var(--color-border);
		border-radius: 8px;
		background: color-mix(in srgb, var(--color-bg-secondary) 88%, transparent);
		padding: 1.2rem;
		box-shadow: 0 22px 55px var(--color-shadow);
	}

	.hero-panel p {
		margin: 0 0 1rem;
		font-size: 1.2rem;
		font-weight: 850;
		line-height: 1.25;
	}

	.hero-panel span {
		color: var(--color-success);
		font-size: 0.95rem;
		font-weight: 750;
	}

	.content {
		width: min(1180px, calc(100% - 2rem));
		margin: 0 auto;
	}

	@media (max-width: 850px) {
		.hero {
			min-height: auto;
			grid-template-columns: 1fr;
			align-items: start;
			padding-top: 5rem;
		}

		.hero-actions a,
		.social-links a {
			flex: 1 1 auto;
		}
	}

	@media (max-width: 480px) {
		.hero {
			padding-top: 4rem;
		}

		.hero-copy > p:not(.eyebrow) {
			font-size: 1.05rem;
		}

		.hero-panel p {
			font-size: 1.05rem;
		}
	}
</style>
