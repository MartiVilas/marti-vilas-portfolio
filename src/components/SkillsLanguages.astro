---
const frameworksAndLanguages = [
	{
		name: "PHP",
		img: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/php/php-original.svg",
	},
	{
		name: "React",
		img: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/react/react-original.svg",
	},
	{
		name: "TypeScript",
		img: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg",
	},
	{
		name: "JavaScript",
		img: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-original.svg",
	},
	{
		name: "NodeJS",
		img: "/nodejs-logo-vector-png.png",
	},
	{
		name: "Kotlin",
		img: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/kotlin/kotlin-original.svg",
	},
	{
		name: "MySQL",
		img: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mysql/mysql-original.svg",
	},
	{
		name: "PostgreSQL",
		img: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/postgresql/postgresql-original.svg",
	},
	{
		name: "Vue",
		img: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/vuejs/vuejs-original.svg",
	},
	{
		name: "GitHub",
		img: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/github/github-original.svg",
	},
	{
		name: "GitLab",
		img: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/gitlab/gitlab-original.svg",
	},
	{
		name: "Git",
		img: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/git/git-original.svg",
	},
	{
		name: "Astro",
		img: "https://cdn.simpleicons.org/astro/FF5A03",
	},
];

const languages = [
	{
		name: "Español",
		level: "Nativo",
	},
	{
		name: "Català",
		level: "Natiu",
	},
	{
		name: "Inglés",
		level: "B2.2",
	},
];
---

<section class="skills-languages" id="skills" aria-labelledby="skills-title">
	<div class="section-heading">
		<p class="eyebrow">Skills & languages</p>
	</div>

	<div class="content-grid">
		<div class="skills-panel">
			<h3>Skills</h3>
			<ul class="skill-list" aria-label="Skills">
				{
					frameworksAndLanguages.map((skill) => (
						<li>
							<img src={skill.img} alt={skill.name} title={skill.name} width="100" height="100" />
						</li>
					))
				}
			</ul>
		</div>

		<div class="language-panel">
			<h3>Idiomes</h3>
			<ul class="language-list" aria-label="Languages">
				{
					languages.map((language) => (
						<li>
							<span>{language.name}</span>
							<strong>{language.level}</strong>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</section>

<style>
	.skills-languages {
		padding: clamp(4rem, 8vw, 7rem) 0;
		border-bottom: 1px solid var(--color-border);
	}

	.section-heading {
		margin-bottom: 2rem;
	}

	.eyebrow {
		margin: 0 0 0.6rem;
		color: var(--color-accent);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.content-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.65fr);
		gap: 1rem;
	}

	.skills-panel,
	.language-panel {
		border: 1px solid var(--color-border);
		border-radius: 8px;
		background: var(--color-bg-secondary);
		padding: clamp(1.1rem, 2vw, 1.5rem);
		box-shadow: 0 18px 45px rgba(var(--color-accent-rgb), 0.08);
	}

	h3 {
		margin: 0 0 1.2rem;
		color: var(--color-text);
		font-size: clamp(1.25rem, 2vw, 1.65rem);
	}

	.skill-list,
	.language-list {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.skill-list {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(96px, 1fr));
		gap: 0.85rem;
	}

	.skill-list li {
		position: relative;
		display: flex;
		min-height: 118px;
		align-items: center;
		justify-content: center;
		padding: 1rem;
	}

	.skill-list li:hover {
		z-index: 2;
	}

	.skill-list img {
		display: block;
		width: min(92px, 100%);
		height: 60px;
		object-fit: contain;
		transition: transform 0.2s ease;
	}

	.skill-list img:hover {
		cursor: pointer;
		transform: scale(1.3);
	}

	.language-list {
		display: grid;
		gap: 0;
	}

	.language-list li {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.95rem 0;
		border-bottom: 1px solid var(--color-border);
	}

	.language-list li:first-child {
		padding-top: 0;
	}

	.language-list li:last-child {
		border-bottom: 0;
		padding-bottom: 0;
	}

	.language-list span {
		color: var(--color-text);
		font-weight: 850;
	}

	.language-list strong {
		color: var(--color-success);
		font-size: 0.95rem;
		text-align: right;
	}

	@media (max-width: 860px) {
		.content-grid {
			grid-template-columns: 1fr;
		}

		.language-list li {
			align-items: start;
			flex-direction: column;
			gap: 0.25rem;
		}

		.language-list strong {
			text-align: left;
		}
	}
</style>
