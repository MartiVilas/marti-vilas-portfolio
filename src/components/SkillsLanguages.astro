---
import { defaultLocale, t, type Locale } from '../i18n';

const { locale = defaultLocale } = Astro.props as { locale?: Locale };
const spokenLanguages = t('spoken_languages', locale);

const frameworksAndLanguages = [
	{
		name: "PHP",
		img: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/php/php-original.svg",
	},
	{
		name: "React",
		img: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/react/react-original.svg",
	},
	{
		name: "TypeScript",
		img: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg",
	},
	{
		name: "JavaScript",
		img: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-original.svg",
	},
	{
		name: "NodeJS",
		img: "/nodejs-logo-vector-png.png",
	},
	{
		name: "Kotlin",
		img: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/kotlin/kotlin-original.svg",
	},
	{
		name: "MySQL",
		img: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mysql/mysql-original.svg",
	},
	{
		name: "PostgreSQL",
		img: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/postgresql/postgresql-original.svg",
	},
	{
		name: "Vue",
		img: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/vuejs/vuejs-original.svg",
	},
	{
		name: "GitHub",
		img: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/github/github-original.svg",
	},
	{
		name: "GitLab",
		img: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/gitlab/gitlab-original.svg",
	},
	{
		name: "Git",
		img: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/git/git-original.svg",
	},
	{
		name: "Astro",
		img: "https://cdn.simpleicons.org/astro/FF5A03",
	},
];
---

<section class="skills-languages" id="skills" aria-label={t('skills_label', locale)}>
	<div class="section-heading">
		<p class="eyebrow">{t('skills_title', locale)}</p>
	</div>

	<div class="carousel" aria-label={t('skills_label', locale)}>
		<div class="carousel-track" role="list">
			{
				[...frameworksAndLanguages, ...frameworksAndLanguages].map((skill, index) => (
					<div class="carousel-item" role="listitem" aria-hidden={index >= frameworksAndLanguages.length}>
						<img src={skill.img} alt={skill.name} title={skill.name} width="100" height="100" loading="lazy" />
					</div>
				))
			}
		</div>
	</div>

	<ul class="spoken-languages" aria-label={t('spoken_languages_label', locale)}>
		{
			spokenLanguages.map((language) => (
				<li class="spoken-language">
					<span class={`fi ${language.flag}`} aria-hidden="true"></span>
					<span class="spoken-language-name">{language.name}</span>
					<span class="spoken-language-level">{language.level}</span>
				</li>
			))
		}
	</ul>
</section>

<style>
	.skills-languages {
		padding: clamp(4rem, 8vw, 7rem) 0;
		border-bottom: 1px solid var(--color-border);
	}

	.section-heading {
		margin-bottom: 2rem;
	}

	.eyebrow {
		margin: 0 0 0.6rem;
		color: var(--color-accent);
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.carousel {
		--gap: 2.5rem;
		--item-size: 92px;
		overflow: hidden;
		position: relative;
		border: 1px solid var(--color-border);
		border-radius: 8px;
		background: var(--color-bg-secondary);
		padding: 1.5rem 0;
		box-shadow: 0 18px 45px rgba(var(--color-accent-rgb), 0.08);
		mask-image: linear-gradient(
			to right,
			transparent 0,
			#000 8%,
			#000 92%,
			transparent 100%
		);
		-webkit-mask-image: linear-gradient(
			to right,
			transparent 0,
			#000 8%,
			#000 92%,
			transparent 100%
		);
	}

	.carousel-track {
		display: flex;
		gap: var(--gap);
		width: max-content;
		animation: skills-scroll 18s linear infinite;
	}

	.carousel-item {
		flex: 0 0 auto;
		display: flex;
		align-items: center;
		justify-content: center;
		width: var(--item-size);
		height: var(--item-size);
	}

	.carousel-item img {
		display: block;
		width: 100%;
		height: 60px;
		object-fit: contain;
		transition: transform 0.2s ease;
	}

	.carousel-item img:hover {
		cursor: pointer;
		transform: scale(1.25);
	}

	@keyframes skills-scroll {
		from {
			transform: translateX(0);
		}
		to {
			transform: translateX(calc(-50% - var(--gap) / 2));
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.carousel-track {
			animation: none;
		}
	}

	@media (max-width: 860px) {
		.carousel {
			--gap: 1.75rem;
			--item-size: 72px;
		}

		.carousel-item img {
			height: 48px;
		}
	}

	.spoken-languages {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.85rem;
		margin: 1.6rem 0 0;
		padding: 0;
		list-style: none;
	}

	.spoken-language {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: var(--color-bg-secondary);
		padding: 0.5rem 1rem;
		color: var(--color-text);
		font-size: 0.95rem;
		font-weight: 700;
	}

	.spoken-language .fi {
		width: 1.3rem;
		border-radius: 2px;
	}

	.spoken-language-name {
		color: var(--color-text);
	}

	.spoken-language-level {
		color: var(--color-success);
		font-weight: 800;
	}

	@media (max-width: 520px) {
		.spoken-languages {
			gap: 0.6rem;
		}

		.spoken-language {
			padding: 0.45rem 0.85rem;
			font-size: 0.88rem;
		}
	}
</style>
