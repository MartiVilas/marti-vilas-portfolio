---
import { defaultLocale, t, type Locale } from '../i18n';

const { locale = defaultLocale } = Astro.props as { locale?: Locale };
---

<section class="synopsis" id="sinopsis" aria-labelledby="synopsis-title">
	<div class="section-copy">
		<p class="eyebrow">{t('synopsis_label', locale)}</p>
		<h2 id="synopsis-title">{t('synopsis_title', locale)}</h2>
	</div>
	<div class="text-stack">
		<p>{t('synopsis_text', locale)}</p>
		<p>{t('portfolio_summary', locale)}</p>
	</div>
</section>

<style>
	.synopsis {
		display: grid;
		grid-template-columns: minmax(0, 0.85fr) minmax(0, 1fr);
		gap: clamp(2rem, 6vw, 5rem);
		padding: clamp(4rem, 8vw, 7rem) 0;
		border-bottom: 1px solid var(--color-border);
	}

	.eyebrow {
		margin: 0 0 0.75rem;
		color: var(--color-accent);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	h2 {
		margin: 0;
		max-width: 760px;
		color: var(--color-text);
		font-size: clamp(1.7rem, 4.5vw, 4.3rem);
		line-height: 1.05;
		font-weight: 850;
	}

	.text-stack {
		display: grid;
		gap: 1.2rem;
		align-content: end;
	}

	p {
		margin: 0;
		color: var(--color-text-muted);
		font-size: clamp(1rem, 1.45vw, 1.18rem);
		line-height: 1.75;
	}

	@media (max-width: 820px) {
		.synopsis {
			grid-template-columns: 1fr;
		}
	}
</style>
