---
import { defaultLocale, t, type Locale } from '../i18n';

const { locale = defaultLocale } = Astro.props as { locale?: Locale };
const experiences = t('experiences', locale);
---

<section class="timeline-section" id="experiencia" aria-labelledby="experience-title">
	<p class="eyebrow">{t('experience_label', locale)}</p>
	<h2 id="experience-title">{t('learning_by_doing_title', locale)}</h2>
	<div class="timeline">
		{
			experiences.map((experience) => (
				<article class="timeline-item">
					<p class="period">{experience.period}</p>
					<div>
						<h3>{experience.role}</h3>
						<p class="place">{experience.place}</p>
						<p>{experience.description}</p>
					</div>
				</article>
			))
		}
	</div>
</section>

<style>
	.timeline-section {
		padding: clamp(4rem, 8vw, 7rem) 0;
		border-bottom: 1px solid var(--color-border);
	}

	.eyebrow {
		margin: 0 0 0.6rem;
		color: var(--color-accent);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	h2 {
		margin: 0 0 2.2rem;
		color: var(--color-text);
		font-size: clamp(2rem, 4vw, 3.6rem);
		line-height: 1.05;
	}

	.timeline {
		display: grid;
		border-top: 1px solid var(--color-border);
	}

	.timeline-item {
		display: grid;
		grid-template-columns: 210px minmax(0, 1fr);
		gap: 2rem;
		padding: 1.6rem 0;
		border-bottom: 1px solid var(--color-border);
	}

	.period {
		margin: 0;
		color: var(--color-accent);
		font-weight: 800;
	}

	h3 {
		margin: 0;
		color: var(--color-text);
		font-size: clamp(1.25rem, 2vw, 1.65rem);
	}

	.place {
		margin: 0.45rem 0 0.8rem;
		color: var(--color-success);
		font-weight: 800;
	}

	p {
		margin: 0;
		color: var(--color-text-muted);
		line-height: 1.65;
	}

	@media (max-width: 720px) {
		.timeline-item {
			grid-template-columns: 1fr;
			gap: 0.5rem;
			padding: 1.4rem 0;
		}

		.period {
			font-size: 0.9rem;
		}

		.place {
			margin: 0.3rem 0 0.6rem;
		}
	}
</style>
