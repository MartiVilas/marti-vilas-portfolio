---
import { defaultLocale, t, type Locale } from '../i18n';

const { locale = defaultLocale } = Astro.props as { locale?: Locale };

const languageLinks = [
	{
		locale: "es",
		href: "/",
		flag: "fi-es",
		label: t('spanish_language', locale),
	},
	{
		locale: "en",
		href: "/en/",
		flag: "fi-gb",
		label: t('english_language', locale),
	},
] as const;

const currentLanguage = languageLinks.find((language) => language.locale === locale) ?? languageLinks[0];
const nextLanguage = languageLinks.find((language) => language.locale !== locale) ?? languageLinks[0];

const navLinks = [
	{ href: "#skills", label: t('skills_link', locale) },
	{ href: "#proyectos", label: t('projects_link', locale) },
	{ href: "#cv", label: t('cv_link', locale) },
	{ href: "#experiencia", label: t('experience_link', locale) },
	{ href: "#estudios", label: t('education_link', locale) },
	{ href: "#contacto", label: t('contact_link', locale) },
] as const;

const themeLabels =
	locale === 'en'
		? {
				light: 'Switch to light mode',
				dark: 'Switch to dark mode',
			}
		: {
				light: 'Cambiar a modo claro',
				dark: 'Cambiar a modo oscuro',
			};
---

<header class="floating-header">
	<a href="#inicio" class="header-brand">{t('home_link', locale)}</a>
	<div class="header-actions">
		<nav class="header-nav" aria-label={t('main_navigation', locale)}>
			{navLinks.map((link) => <a class="header-nav-link" href={link.href}>{link.label}</a>)}
		</nav>
		<div class="header-tools">
			<a class="header-language" href={nextLanguage.href} aria-label={nextLanguage.label} title={nextLanguage.label}>
				<span class={`fi ${currentLanguage.flag}`} aria-hidden="true"></span>
			</a>
			<button
				class="theme-toggle"
				type="button"
				data-theme-toggle
				data-light-label={themeLabels.light}
				data-dark-label={themeLabels.dark}
				aria-label={themeLabels.light}
				title={themeLabels.light}
			>
				<svg
					class="theme-icon theme-icon-dark"
					viewBox="0 0 35 35"
					aria-hidden="true"
					focusable="false"
				>
					<path
						fill="currentColor"
						d="M18.44,34.68a18.22,18.22,0,0,1-2.94-.24,18.18,18.18,0,0,1-15-20.86A18.06,18.06,0,0,1,9.59.63,2.42,2.42,0,0,1,12.2.79a2.39,2.39,0,0,1,1,2.41L11.9,3.1l1.23.22A15.66,15.66,0,0,0,23.34,21h0a15.82,15.82,0,0,0,8.47.53A2.44,2.44,0,0,1,34.47,25,18.18,18.18,0,0,1,18.44,34.68ZM10.67,2.89a15.67,15.67,0,0,0-5,22.77A15.66,15.66,0,0,0,32.18,24a18.49,18.49,0,0,1-9.65-.64A18.18,18.18,0,0,1,10.67,2.89Z"
					/>
				</svg>
				<svg
					class="theme-icon theme-icon-light"
					viewBox="0 0 24 24"
					aria-hidden="true"
					focusable="false"
				>
					<path
						fill="currentColor"
						d="M12 0a1 1 0 0 1 1 1v4a1 1 0 1 1-2 0V1a1 1 0 0 1 1-1ZM4.929 3.515a1 1 0 0 0-1.414 1.414l2.828 2.828a1 1 0 0 0 1.414-1.414L4.93 3.515ZM1 11a1 1 0 1 0 0 2h4a1 1 0 1 0 0-2H1ZM18 12a1 1 0 0 1 1-1h4a1 1 0 1 1 0 2h-4a1 1 0 0 1-1-1ZM17.657 16.243a1 1 0 0 0-1.414 1.414l2.828 2.828a1 1 0 1 0 1.414-1.414l-2.828-2.828ZM7.757 17.657a1 1 0 1 0-1.414-1.414L3.515 19.07a1 1 0 1 0 1.414 1.414l2.828-2.828ZM20.485 4.929a1 1 0 0 0-1.414-1.414l-2.828 2.828a1 1 0 1 0 1.414 1.414l2.828-2.828ZM13 19a1 1 0 1 0-2 0v4a1 1 0 1 0 2 0v-4ZM12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10Z"
					/>
				</svg>
			</button>
		</div>
	</div>
</header>

<script>
	function initThemeToggle(button: HTMLButtonElement) {
		const root = document.documentElement

		function setTheme(theme: 'light' | 'dark') {
			root.dataset.theme = theme
			localStorage.setItem('theme', theme)
			const isLight = theme === 'light'
			const label = isLight ? button.dataset.darkLabel : button.dataset.lightLabel
			if (label) {
				button.setAttribute('aria-label', label)
				button.title = label
			}
			button.dataset.activeTheme = theme
		}

		setTheme(root.dataset.theme === 'light' ? 'light' : 'dark')

		button.addEventListener('click', () => {
			setTheme(root.dataset.theme === 'light' ? 'dark' : 'light')
		})
	}

	document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach(initThemeToggle)
</script>

<style>
	.floating-header {
		--header-text: var(--color-header-text);
		--header-text-hover: var(--color-header-text-hover);
		position: sticky;
		top: 5px;
		z-index: 10;
		display: flex;
		align-items: center;
		justify-content: center;
		width: fit-content;
		max-width: calc(100% - 2rem);
		margin: 13px auto 0;
		gap: 1.2rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: var(--color-header-bg);
		padding: 0.65rem 0.75rem 0.65rem 1rem;
		backdrop-filter: blur(18px);
		box-shadow: 0 18px 45px var(--color-shadow);
	}

	.header-brand,
	.header-brand:link,
	.header-brand:visited,
	.header-nav-link,
	.header-nav-link:link,
	.header-nav-link:visited {
		color: var(--header-text) !important;
		text-decoration: none;
	}

	.header-brand {
		font-weight: 900;
	}

	.header-actions {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1rem;
	}

	.header-tools {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
	}

	.header-nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.45rem 1rem;
		font-size: 0.95rem;
		font-weight: 700;
	}

	.header-brand:hover,
	.header-nav-link:hover {
		color: var(--header-text-hover) !important;
	}

	.header-language {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.2rem;
		height: 1.65rem;
		background: transparent;
		cursor: pointer;
		text-decoration: none;
		transition: transform 0.2s ease;
	}

	.header-language:hover {
		transform: translateY(-1px);
	}

	.theme-toggle {
		display: inline-grid;
		width: 2.2rem;
		height: 2.2rem;
		place-items: center;
		border: 0;
		background: transparent;
		color: var(--color-accent);
		cursor: pointer;
		transition:
			transform 0.2s ease;
	}

	.theme-toggle[data-active-theme="dark"] {
		color: #38bdf8;
	}

	.theme-toggle[data-active-theme="light"] {
		color: #f59e0b;
	}

	.theme-toggle:hover {
		transform: translateY(-1px);
	}

	.theme-icon {
		display: block;
		width: 1.08rem;
		height: 1.08rem;
	}

	.theme-icon-light {
		display: none;
	}

	.theme-toggle[data-active-theme="light"] .theme-icon-dark {
		display: none;
	}

	.theme-toggle[data-active-theme="light"] .theme-icon-light {
		display: block;
	}

	.fi {
		width: 1.45rem;
		border-radius: 2px;
		box-shadow: none;
	}

	@media (max-width: 850px) {
		.floating-header {
			align-items: center;
			flex-direction: column;
			border-radius: 22px;
			padding: 0.85rem 1rem;
			gap: 0.85rem;
		}

		.header-actions {
			align-items: center;
			flex-direction: column;
			gap: 0.75rem;
		}

		.header-nav {
			justify-content: center;
			gap: 0.4rem 0.85rem;
			font-size: 0.88rem;
		}
	}

	@media (max-width: 480px) {
		.floating-header {
			width: calc(100% - 1rem);
			max-width: calc(100% - 1rem);
			padding: 0.75rem 0.9rem;
		}

		.header-nav {
			font-size: 0.82rem;
			gap: 0.35rem 0.7rem;
		}
	}
</style>
