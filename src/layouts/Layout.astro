---
import "flag-icons/css/flag-icons.min.css";
import { defaultLocale, t, type Locale } from '../i18n';

const { locale = defaultLocale } = Astro.props as { locale?: Locale };
---

<!doctype html>
<html lang={locale}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content={t('meta_description', locale)}
		/>
		<title>{t('page_title', locale)}</title>
		<script is:inline>
			const savedTheme = localStorage.getItem('theme');
			document.documentElement.dataset.theme = savedTheme === 'light' ? 'light' : 'dark';
		</script>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	:root {
		color-scheme: dark;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		--color-bg: #0b1220;
		--color-bg-secondary: #111c2e;
		--color-bg-tertiary: #0f172a;
		--color-card: #111c2e;
		--color-card-alt: #0f172a;
		--color-primary: #2563eb;
		--color-primary-hover: #1d4ed8;
		--color-accent: #38bdf8;
		--color-accent-rgb: 56, 189, 248;
		--color-accent-soft: rgba(var(--color-accent-rgb), 0.12);
		--color-text: #eaf2ff;
		--color-text-muted: #94a3b8;
		--color-border: #1e293b;
		--color-success: #22c55e;
		--color-button-text: #eaf2ff;
		--color-shadow: rgba(0, 0, 0, 0.26);
		--color-shadow-strong: rgba(0, 0, 0, 0.42);
		--color-header-bg: rgba(11, 18, 32, 0.88);
		--color-header-text: #d7e8ff;
		--color-header-text-hover: #ffffff;
		--color-hero-overlay-start: rgba(11, 18, 32, 0.96);
		--color-hero-overlay-end: rgba(17, 28, 46, 0.86);
		--color-chat-bg: rgba(11, 18, 32, 0.98);
		background: var(--color-bg);
		color: var(--color-text);
	}

	:root[data-theme="light"] {
		color-scheme: light;
		--color-bg: #f8fafc;
		--color-bg-secondary: #ffffff;
		--color-bg-tertiary: #eef6ff;
		--color-card: #ffffff;
		--color-card-alt: #f1f7ff;
		--color-primary: #2563eb;
		--color-primary-hover: #1d4ed8;
		--color-accent: #0284c7;
		--color-accent-rgb: 2, 132, 199;
		--color-accent-soft: #dbeafe;
		--color-text: #0f172a;
		--color-text-muted: #475569;
		--color-border: #d7e5f5;
		--color-success: #22c55e;
		--color-button-text: #ffffff;
		--color-shadow: rgba(15, 23, 42, 0.08);
		--color-shadow-strong: rgba(15, 23, 42, 0.16);
		--color-header-bg: rgba(255, 255, 255, 0.88);
		--color-header-text: #0f172a;
		--color-header-text-hover: #1d4ed8;
		--color-hero-overlay-start: rgba(248, 250, 252, 0.96);
		--color-hero-overlay-end: rgba(238, 246, 255, 0.88);
		--color-chat-bg: rgba(255, 255, 255, 0.98);
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		scroll-behavior: smooth;
	}

	body {
		background: linear-gradient(
			135deg,
			var(--color-bg) 0%,
			var(--color-bg-tertiary) 55%,
			var(--color-bg-secondary) 100%
		);
		overflow-x: hidden;
	}

	* {
		box-sizing: border-box;
	}

	a {
		color: inherit;
	}
</style>
